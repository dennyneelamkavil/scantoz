# Database Connection
MONGODB_URI="mongodb://localhost:27017/scantoz"

# NextAuth Configuration
NEXTAUTH_SECRET="your-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# JWT Secret for Token Signing
JWT_SECRET="your-jwt-secret-key"

# Seller JWT Secret for Seller Authentication
SELLER_JWT_SECRET="your-seller-jwt-secret-key"

# Customer JWT Secret for Customer Authentication
CUSTOMER_JWT_SECRET="your-customer-jwt-secret-key"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx

# Site URLs
NEXT_PUBLIC_ADMIN_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3001"

# OpenAI API Key
OPENAI_API_KEY="your-openai-api-key"